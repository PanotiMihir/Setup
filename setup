#!/bin/bash

LOG="$HOME/setup.log"
exec > >(tee -a "$LOG") 2>&1

echo "========== UBUNTU KINGDOM SETUP STARTED =========="
date

# ----------------------------------------
# 1. INIT
# ----------------------------------------
echo "== Initializing sudo keepalive =="

sudo -v
while true; do sudo -n true; sleep 60; done 2>/dev/null &
SUDO_PID=$!

# ----------------------------------------
# 2. SYSTEM UPDATE + CORE PACKAGES
# ----------------------------------------
echo "== Updating system and installing core packages =="

sudo apt update

sudo apt install -y \
  curl \
  git \
  wget \
  zsh \
  unzip \
  software-properties-common \
  apt-transport-https \
  gpg \
  ca-certificates\
  lolcat\
  cowsay

# ----------------------------------------
# 3. REPOSITORY SETUP
# ----------------------------------------
echo "== Adding Brave repository =="

sudo curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg \
https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg

echo "deb [signed-by=/usr/share/keyrings/brave-browser-archive-keyring.gpg] \
https://brave-browser-apt-release.s3.brave.com/ stable main" | \
sudo tee /etc/apt/sources.list.d/brave-browser-release.list > /dev/null

echo "== Adding VS Code repository =="

wget -qO- https://packages.microsoft.com/keys/microsoft.asc | \
gpg --dearmor | \
sudo tee /usr/share/keyrings/packages.microsoft.gpg > /dev/null

echo "deb [arch=amd64 signed-by=/usr/share/keyrings/packages.microsoft.gpg] \
https://packages.microsoft.com/repos/code stable main" | \
sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null

sudo apt update

# ----------------------------------------
# 4. APPLICATION INSTALL PHASE (APT)
# ----------------------------------------
echo "== Installing applications via apt =="

sudo apt install -y \
  brave-browser \
  code

echo "== Removing Firefox snap =="
sudo snap remove firefox || true

# ----------------------------------------
# 5. MANUAL INSTALLS (/opt)
# ----------------------------------------

echo "== Installing Godot to /opt/godot =="

sudo mkdir -p /opt/godot
cd /opt/godot

GODOT_URL=$(curl -s https://api.github.com/repos/godotengine/godot/releases/latest \
| grep browser_download_url \
| grep "linux.x86_64.zip" \
| grep -v mono \
| head -n 1 \
| cut -d '"' -f4)

sudo wget "$GODOT_URL" -O godot.zip
sudo unzip -o godot.zip
sudo rm godot.zip
sudo chmod +x Godot_*_linux.x86_64
sudo ln -sf /opt/godot/Godot_*_linux.x86_64 /usr/local/bin/godot

cd ~

echo "== Installing Discord to /opt/discord =="

wget -O discord.tar.gz "https://discord.com/api/download?platform=linux&format=tar.gz"
tar -xzf discord.tar.gz
rm discord.tar.gz

sudo rm -rf /opt/discord
sudo mv Discord /opt/discord
sudo chown -R root:root /opt/discord
sudo chmod 4755 /opt/discord/chrome-sandbox
sudo ln -sf /opt/discord/Discord /usr/local/bin/discord

sudo tee /usr/share/applications/discord.desktop > /dev/null <<EOF
[Desktop Entry]
Name=Discord
Comment=Chat for communities and friends
Exec=/opt/discord/Discord
Icon=/opt/discord/discord.png
Terminal=false
Type=Application
Categories=Network;InstantMessaging;
StartupWMClass=discord
EOF

sudo update-desktop-database

# ----------------------------------------
# 6. SHELL SETUP (ZSH + OH MY ZSH + AUTOSUGGESTIONS)
# ----------------------------------------
echo "== Setting Zsh as default shell =="
chsh -s "$(which zsh)" || true

echo "== Installing Oh My Zsh =="
RUNZSH=no CHSH=no sh -c \
"$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

echo "== Installing Zsh Autosuggestions =="

ZSH_CUSTOM=${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}

git clone https://github.com/zsh-users/zsh-autosuggestions \
$ZSH_CUSTOM/plugins/zsh-autosuggestions

echo "plugins=(git zsh-autosuggestions)" >> "$HOME/.zshrc"

# ----------------------------------------
# 7. GNOME TERMINAL THEME
# ----------------------------------------
echo "== Applying GNOME Terminal theme =="

PROFILE=b1dcc9dd-5262-4d8d-a863-c897e6d979b9

gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:$PROFILE/ use-theme-colors false
gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:$PROFILE/ background-color '#000000'
gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:$PROFILE/ foreground-color '#A0A0A0'
gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:$PROFILE/ cursor-colors-set true
gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:$PROFILE/ cursor-foreground-color '#000000'
gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:$PROFILE/ cursor-background-color '#A0A0A0'

# ----------------------------------------
# 8. CUSTOM SCRIPTS INSTALL
# ----------------------------------------
echo "== Installing custom scripts =="

git clone https://github.com/PanotiMihir/scripts
cd scripts || exit 1

for file in *; do
  if [ "$file" != "README.md" ] && [ -f "$file" ]; then
    sudo install -m 755 "$file" /usr/local/bin/
  fi
done

cd ..
rm -rf scripts

# ----------------------------------------
# 9. SSH KEY (NON-INTERACTIVE)
# ----------------------------------------
echo "== Generating SSH key =="

mkdir -p "$HOME/.ssh"
ssh-keygen -t ed25519 -C "panotmihir123@gmail.com" \
-f "$HOME/.ssh/id_ed25519" -N ""

# ----------------------------------------
# 10. VS CODE EXTENSIONS
# ----------------------------------------
echo "== Installing VS Code extensions =="

code --install-extension openai.chatgpt || true
code --install-extension geequlim.godot-tools || true

# ----------------------------------------
# 11. TO-DO FILE (MANUAL TASKS ONLY)
# ----------------------------------------
echo "== Creating to-do list =="

cat <<EOF > "$HOME/to-do.txt"
MANUAL TASKS:
- Add SSH public key to GitHub/GitLab
- Verify GNOME Terminal profile UUID matches
- Log into Brave
- Log into Discord
- Verify Zsh is default shell after reboot
EOF

# ----------------------------------------
# 12. CLEANUP
# ----------------------------------------
echo "== Cleaning up unused packages =="

sudo apt autoremove -y

kill $SUDO_PID

# ----------------------------------------
# 13. GRUB DRIP INSTALL (VIMIX CLEAN)
# ----------------------------------------
echo "== Installing GRUB Vimix theme and clean config =="

cd ~

# Clone theme
git clone https://github.com/vinceliuice/grub2-themes.git
cd grub2-themes || exit 1

sudo ./install.sh -t vimix -s 2k

cd ~
rm -rf grub2-themes

echo "== Applying clean GRUB settings =="

sudo sed -i 's/^GRUB_TIMEOUT_STYLE=.*/GRUB_TIMEOUT_STYLE=menu/' /etc/default/grub
sudo sed -i 's/^GRUB_TIMEOUT=.*/GRUB_TIMEOUT=30/' /etc/default/grub

echo 'GRUB_DISABLE_RECOVERY=true' | sudo tee -a /etc/default/grub > /dev/null
echo 'GRUB_DISABLE_SUBMENU=y' | sudo tee -a /etc/default/grub > /dev/null

# Disable memtest
sudo chmod -x /etc/grub.d/20_memtest86+ 2>/dev/null || true

sudo update-grub

echo "========== SETUP COMPLETE =========="
date

echo "System will power off in 10 seconds..."
sleep 10

sudo poweroff